# OpenAI API Configuration
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_API_VERSION=v1

# Model Configuration
GRAPHRAG_LLM_MODEL=gpt-4o-mini
GRAPHRAG_EMBEDDING_MODEL=text-embedding-ada-002
KGGEN_LLM_MODEL=gpt-4o

# GraphRAG Configuration
GRAPHRAG_CHUNK_SIZE=300
GRAPHRAG_CHUNK_OVERLAP=100
GRAPHRAG_MAX_TOKENS=16384
GRAPHRAG_TEMPERATURE=0

# kg-gen Configuration
KGGEN_CLUSTERING_THRESHOLD=0.85
KGGEN_MIN_CLUSTER_SIZE=2
KGGEN_EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# Neo4j Configuration (Optional)
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your-neo4j-password

# LanceDB Configuration (Optional)
LANCEDB_URI=./lancedb

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=./logs/snu_kg.log

# Pipeline Configuration
PIPELINE_BATCH_SIZE=10
PIPELINE_WORKERS=4
PIPELINE_TIMEOUT=3600

# Output Configuration
OUTPUT_FORMAT=parquet
SAVE_INTERMEDIATE=true
ENABLE_VISUALIZATION=true